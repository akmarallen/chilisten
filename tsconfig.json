{
  "include": ["**/*"],
  "exclude": ["dist"],
  "compilerOptions": {
    "noEmit": true,
    "strict": true,
    "jsx": "react-jsx",
    "jsxImportSource": "react",
    "types": ["vite/client"],
    "esModuleInterop": true,
    "moduleResolution": "Bundler",
    "module": "ES2022",
    "target": "ES2015",
    "resolveJsonModule": true,
    "skipLibCheck": true,
    "lib": ["ESNext", "DOM"]
  }
}
